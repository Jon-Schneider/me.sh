#!/bin/sh

set -u

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/starship-github-pr"
session_cache="${STARSHIP_GITHUB_PR_SESSION_CACHE:-}"

print_pr() {
  pr="$1"
  url="${2:-}"

  case "$url" in
    http://*|https://*)
      printf '\033]8;;%s\007%s\033]8;;\007' "$url" "$pr"
      ;;
    *)
      printf "%s" "$pr"
      ;;
  esac
}

read_cached_pr() {
  file="$1"

  {
    IFS= read -r pr || return 1
    IFS= read -r url || url=""
  } < "$file"

  [ -n "$pr" ] || return 1
  print_pr "$pr" "$url"
}

if [ -n "$session_cache" ]; then
  [ -s "$session_cache" ] || exit 1
  read_cached_pr "$session_cache" || exit 1
  exit 0
fi

git_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 1
branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)" || exit 1

[ "$branch" != "HEAD" ] || exit 1

key="$(printf '%s\n%s\n' "$git_root" "$branch" | shasum -a 256 | awk '{print $1}')"
cache_file="$cache_dir/$key"

[ -s "$cache_file" ] || exit 1

read_cached_pr "$cache_file"
