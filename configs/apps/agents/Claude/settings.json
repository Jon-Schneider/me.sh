{
  "env": {
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "permissions": {
    "allow": [
      "Bash(diff:*)",
      "Bash(git diff:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Edit(~/**/*)",
      "Write(~/**/*)"
    ],
    "deny": [
      "Bash(swiftformat:*)"
    ]
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/$(whoami)/bin/set_tmux_agent_status running"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/$(whoami)/bin/set_tmux_agent_status running"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/$(whoami)/bin/set_tmux_agent_status running"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/$(whoami)/bin/set_tmux_agent_status needs-input"
          },
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Funk.aiff"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/$(whoami)/bin/set_tmux_agent_status needs-input"
          },
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Funk.aiff"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/$(whoami)/bin/set_tmux_agent_status ready"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/$(whoami)/bin/set_tmux_agent_status done"
          },
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Submarine.aiff"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/$(whoami)/bin/set_tmux_agent_status ready"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/$(whoami)/bin/set_tmux_agent_status \"\""
          }
        ]
      }
    ]
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "bash /Users/$(whoami)/.claude/statusline-command.sh"
  },
  "env": {
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowRead": ["~/Library/Developer"],
      "denyRead": ["~/.ssh, ~/Documents, ~/Tmp, ~/Library"]
    },
    "network": {
      "allowedDomains": ["github.com"]
    }
  }
}
