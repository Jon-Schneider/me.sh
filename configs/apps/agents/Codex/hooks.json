{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/bin/set_tmux_agent_status ready"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/bin/set_tmux_agent_status running"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/bin/set_tmux_agent_status running-tool"
          }
        ]
      },
      {
        "hooks" : [
          {
            "command" : "$HOME/bin/codex-block-raw-apple-build-tools",
            "type" : "command"
          }
        ],
        "matcher" : "Bash"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/bin/set_tmux_agent_status running"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/bin/set_tmux_agent_status done"
          }
        ]
      }
    ]
  }
}
