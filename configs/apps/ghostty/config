# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms

theme = jon
copy-on-select = clipboard

# Split keybindings. Each Cmd combo sends Ctrl-Space (tmux prefix \x00) + a
# letter bound in .tmux.conf. Option = "stay" (keep focus on original pane).
#   Cmd+Enter            -> prefix+v -> split right, focus NEW pane
#   Cmd+Opt+Enter        -> prefix+o -> split right, stay on original (-d)
#   Cmd+Shift+Enter      -> prefix+s -> split down,  focus NEW pane
#   Cmd+Shift+Opt+Enter  -> prefix+e -> split down,  stay on original (-d)
# NB: super+shift+enter must be explicitly bound here to override Ghostty's
# built-in toggle_split_zoom ("Zoom Split"), which otherwise eats the key.
keybind = super+enter=text:\x00v
keybind = super+alt+enter=text:\x00o
keybind = super+shift+enter=text:\x00s
keybind = super+shift+alt+enter=text:\x00e
keybind = cmd+z=text:\x00z
keybind = cmd+d=unbind
keybind = super+shift+left=text:\x00Y
keybind = super+shift+right=text:\x00L
keybind = super+shift+up=text:\x00K
keybind = super+shift+down=text:\x00J
# Route macOS window-management chords through tmux so Herdr can use them for
# spaces and tabs while other panes retain their existing behavior.
keybind = super+w=text:\x17
keybind = super+s=text:\x00S
keybind = super+x=text:\x00G
keybind = super+c=text:\x00F
keybind = super+n=text:\x00N
keybind = super+t=text:\x00T
keybind = super+q=text:\x00Q
keybind = ctrl+tab=text:\x00n
keybind = ctrl+shift+tab=text:\x00p

# Disable toggling fullscreen
keybind = super+ctrl+f=unbind

keybind = cmd+left=text:\x00B
keybind = cmd+right=text:\x1b[F
# Karabiner consumes Cmd+Ctrl+Arrow before AppKit can emit NSBeep and sends
# these otherwise-unused function keys instead.
keybind = f13=text:\x00\x1b[D
keybind = f14=text:\x00\x1b[C
keybind = f15=text:\x00\x1b[A
keybind = f16=text:\x00\x1b[B
keybind = cmd+backspace=text:\x00D

# Enable Shift + Enter going to new line in 'git commit -m "..."'
keybind = shift+enter=text:\n
